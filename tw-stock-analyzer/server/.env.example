# Server Configuration
PORT=3001
NODE_ENV=development

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Client URL (for email links)
CLIENT_URL=http://localhost:5173

# Email (SMTP) - Use Ethereal for development
# https://ethereal.email
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your-ethereal-user
SMTP_PASS=your-ethereal-pass
EMAIL_FROM="台股分析系統 <noreply@twstock.com>"

# Database
# For SQLite (default), no config needed
# For PostgreSQL, set:
# DATABASE_URL=postgresql://user:password@localhost:5432/twstock

# AI Service Configuration
AI_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-api-key
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Pro Member Daily Limit (default: 50)
PRO_DAILY_LIMIT=50
